<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context="com.example.localgrub.ui.screens.order.OrderFragment">

    <com.google.android.material.loadingindicator.LoadingIndicator
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone" />

    <!-- Delivery Details Section (Fixed at the Top) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/deliveryDetailsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/deliveryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delivery Details"
                android:textAppearance="?attr/textAppearanceHeadline6"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/editProfileButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Profile"
                android:letterSpacing="0"
                android:textColor="@color/green"
                app:layout_constraintBaseline_toBaselineOf="@+id/deliveryTitle"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/nameTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:drawableStart="@drawable/ic_person"
                android:drawableTint="@color/orange"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:text="Kamlesh Prajapat"
                android:maxLines="1"
                android:ellipsize="end"
                android:textAppearance="?attr/textAppearanceBody1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/deliveryTitle" />

            <TextView
                android:id="@+id/phoneNumberTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:drawableStart="@drawable/ic_phone"
                android:drawableTint="@color/orange"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:text="+91 9587216569"
                android:maxLength="14"
                android:textAppearance="?attr/textAppearanceBody1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/nameTextView" />

            <TextView
                android:id="@+id/addressTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:drawableStart="@drawable/ic_location"
                android:drawableTint="@color/orange"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:text="Sardarshahar, Churu"
                android:maxLines="3"
                android:ellipsize="end"
                android:textAppearance="?attr/textAppearanceBody1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/phoneNumberTextView" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Order Summary Section (Fills the remaining space) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/orderDetailsCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toTopOf="@+id/placeOrderButton"
        app:layout_constraintTop_toBottomOf="@+id/deliveryDetailsCard">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <TextView
                android:id="@+id/orderSummaryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order Details"
                android:textAppearance="?attr/textAppearanceHeadline6"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:layout_constraintHeight_max="300dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/orderSummaryTitle">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/orderItemsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/order_item_summary_row" />
            </androidx.core.widget.NestedScrollView>


            <TextView
                android:id="@+id/totalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item Total"
                android:layout_marginBottom="11dp"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:textColor="@color/gray_text"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/deliveryFeeLabel"
                app:layout_constraintStart_toStartOf="@+id/deliveryFeeLabel" />

            <TextView
                android:id="@+id/totalTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs. 250"
                android:textColor="@color/gray_text"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/totalLabel"
                app:layout_constraintEnd_toEndOf="@+id/deliveryFeeTextView"
                app:layout_constraintTop_toTopOf="@+id/totalLabel" />

            <TextView
                android:id="@+id/deliveryFeeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delivery Fee"
                android:layout_marginBottom="16dp"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:textColor="@color/gray_text"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/divider"
                app:layout_constraintStart_toStartOf="@+id/grandTotalLabel" />

            <TextView
                android:id="@+id/deliveryFeeTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs. 20"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/gray_text"
                app:layout_constraintBottom_toBottomOf="@+id/deliveryFeeLabel"
                app:layout_constraintEnd_toEndOf="@+id/grandTotalPriceTextView"
                app:layout_constraintTop_toTopOf="@+id/deliveryFeeLabel" />

            <TextView
                android:id="@+id/grandTotalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grand Total"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/grandTotalPriceTextView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/grandTotalPriceTextView" />

            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="?android:attr/listDivider"
                app:layout_constraintBottom_toTopOf="@+id/grandTotalLabel" />

            <TextView
                android:id="@+id/grandTotalPriceTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs. 270"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Place Order Button (Fixed at the Bottom) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/placeOrderButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cornerRadius="12dp"
        android:backgroundTint="@color/button_bg_color"
        android:textColor="@color/btn_text_color"
        android:text="Place Order"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>