<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.localgrub.ui.screens.splash.SplashFragment"
        android:label="Splash Fragment"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"/>

        <action
            android:id="@+id/action_splashFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.localgrub.ui.screens.auth.login.LoginFragment"
        android:label="Login Fragment"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>

        <action
            android:id="@+id/action_loginFragment_to_otpFragment"
            app:destination="@id/otpFragment"/>
    </fragment>

    <fragment
        android:id="@+id/otpFragment"
        android:name="com.example.localgrub.ui.screens.auth.otp.OtpFragment"
        android:label="Otp Fragment"
        tools:layout="@layout/fragment_otp">

        <argument
            android:name="phone_number"
            app:argType="string"/>

        <action
            android:id="@+id/action_otpFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
    </fragment>
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.localgrub.ui.screens.home.HomeFragment"
        android:label="Home Fragment"
        tools:layout="@layout/fragment_home" >

        <action
            android:id="@+id/action_homeFragment_to_profileBuilderFragment"
            app:destination="@id/profileBuilderFragment"/>

        <action
            android:id="@+id/action_homeFragment_to_orderFragment"
            app:destination="@id/orderFragment"/>

        <action
            android:id="@+id/action_homeFragment_to_historyFragment"
            app:destination="@id/historyFragment"/>

        <action
            android:id="@+id/action_homeFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/profileBuilderFragment"
        android:name="com.example.localgrub.ui.screens.profilebuilder.ProfileBuilderFragment"
        android:label="Create Your Profile Fragment"
        tools:layout="@layout/fragment_profile_builder">

        <argument
            android:name="user"
            app:argType="com.example.localgrub.data.model.GetUser"
            app:nullable="true"
            android:defaultValue="@null"/>

        <action
            android:id="@+id/action_profileBuilderFragment_to_orderFragment"
            app:destination="@id/orderFragment"
            app:popUpTo="@id/profileBuilderFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/orderFragment"
        android:name="com.example.localgrub.ui.screens.order.OrderFragment"
        android:label="Order Fragment"
        tools:layout="@layout/fragment_order">

        <action
            android:id="@+id/action_orderFragment_to_profileBuilderFragment"
            app:destination="@+id/profileBuilderFragment"/>

        <action
            android:id="@+id/action_orderFragment_to_eachOrderStatusFragment"
            app:destination="@+id/eachOrderStatusFragment"
            app:popUpTo="@id/orderFragment"
            app:popUpToInclusive="true"/>

    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.localgrub.ui.screens.history.HistoryFragment"
        android:label="History Fragment"
        tools:layout="@layout/fragment_history">

        <argument
            android:name="uid"
            app:argType="string"/>

        <action
            android:id="@+id/action_historyFragment_to_eachOrderStatusFragment"
            app:destination="@+id/eachOrderStatusFragment"/>
    </fragment>

    <fragment
        android:id="@+id/eachOrderStatusFragment"
        android:name="com.example.localgrub.ui.screens.orderstatus.OrderStatusFragment"
        android:label="Each Order Status Fragment"
        tools:layout="@layout/fragment_order_status">

        <argument
            android:name="orderId"
            app:argType="string"/>
    </fragment>

</navigation>